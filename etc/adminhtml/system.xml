<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="system">
            <group id="full_page_cache">
                <group id="trident" translate="label" sortOrder="610" showInDefault="1">
                    <label>Trident Configuration</label>
                    <field id="api_url" type="text" translate="label comment" sortOrder="10" showInDefault="1">
                        <label>API URL</label>
                        <comment>Trident Admin API URL (e.g., http://trident:9301)</comment>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="api_token" type="obscure" translate="label comment" sortOrder="20" showInDefault="1">
                        <label>API Token</label>
                        <comment>Bearer token for Trident Admin API authentication</comment>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="soft_purge" type="select" translate="label comment" sortOrder="30" showInDefault="1">
                        <label>Soft Purge</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment>Enable soft purge for stale-while-revalidate behavior. Recommended for high-traffic sites.</comment>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="debug" type="select" translate="label comment" sortOrder="40" showInDefault="1">
                        <label>Debug Mode</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment>Enable debug logging for Trident cache operations</comment>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="ttl" type="text" translate="label comment" sortOrder="50" showInDefault="1">
                        <label>Default TTL (seconds)</label>
                        <comment>Public content default time-to-live in seconds. Default: 86400 (24 hours)</comment>
                        <validate>validate-digits</validate>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="grace_period" type="text" translate="label comment" sortOrder="60" showInDefault="1">
                        <label>Grace Period (seconds)</label>
                        <comment>Serve stale content for this duration after expiry while revalidating. Default: 86400 (24 hours)</comment>
                        <validate>validate-digits</validate>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="ttl_static" type="text" translate="label comment" sortOrder="70" showInDefault="1">
                        <label>Static Assets TTL (seconds)</label>
                        <comment>TTL for static assets (/static/, /media/). Default: 2592000 (30 days)</comment>
                        <validate>validate-digits</validate>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="esi_enabled" type="select" translate="label comment" sortOrder="80" showInDefault="1">
                        <label>Enable ESI</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment>Enable Edge Side Includes processing. Trident will process esi:include tags in responses.</comment>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                        </depends>
                    </field>
                    <field id="esi_max_depth" type="text" translate="label comment" sortOrder="90" showInDefault="1">
                        <label>ESI Max Nesting Depth</label>
                        <comment>Maximum depth for nested ESI includes. Default: 3</comment>
                        <validate>validate-digits</validate>
                        <depends>
                            <field id="*/*/caching_application">3</field>
                            <field id="*/*/esi_enabled">1</field>
                        </depends>
                    </field>
                    <depends>
                        <field id="caching_application">3</field>
                    </depends>
                </group>
            </group>
        </section>
    </system>
</config>
