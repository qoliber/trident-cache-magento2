declare(strict_types=1);

use Magento\Backend\Block\Template;
use Magento\Framework\Escaper;
use Qoliber\TridentCache\ViewModel\Entries;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var Entries $viewModel */
$viewModel = $block->getData('view_model');

$page = max(1, (int)$block->getRequest()->getParam('page', 1));
$tagFilter = $block->getRequest()->getParam('tag_filter', '');
$sort = $block->getRequest()->getParam('sort', 'age');
$limit = 50;
$offset = ($page - 1) * $limit;
?>

<div class="trident-entries-container">
    <?php if (!$viewModel->isTridentConfigured()): ?>
        <div class="message message-warning">
            <span><?= $escaper->escapeHtml(__('Trident Cache is not configured as the caching application. Please go to Stores > Configuration > Advanced > System > Full Page Cache and select "Trident" as the caching application.')) ?></span>
        </div>
    <?php elseif (!$viewModel->isEnabled()): ?>
        <div class="message message-warning">
            <span><?= $escaper->escapeHtml(__('Trident Cache is enabled but the API URL is not configured. Please configure the API URL in Stores > Configuration > Advanced > System > Full Page Cache > Trident Configuration.')) ?></span>
        </div>
    <?php else: ?>
        <?php $data = $viewModel->getEntries($offset, $limit, $tagFilter ?: null, $sort); ?>
        <?php if ($data === null): ?>
            <div class="message message-error">
                <span><?= $escaper->escapeHtml(__('Unable to connect to Trident API at %1. Please check the connection and credentials.', $viewModel->getApiUrl())) ?></span>
            </div>
        <?php else: ?>
            <?php
            $entries = $data['entries'] ?? [];
            $total = (int)($data['total'] ?? 0);
            $totalPages = max(1, (int)ceil($total / $limit));
            ?>

            <!-- Filters -->
            <div class="trident-card trident-card-filters">
                <h3 class="trident-card-title"><?= $escaper->escapeHtml(__('Filter Cache Entries')) ?></h3>
                <form action="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries')) ?>" method="get" class="trident-filter-form">
                    <div class="trident-filter-row">
                        <div class="trident-filter-field">
                            <label for="trident_tag_filter"><?= $escaper->escapeHtml(__('Tag')) ?></label>
                            <input type="text"
                                   id="trident_tag_filter"
                                   name="tag_filter"
                                   class="admin__control-text"
                                   value="<?= $escaper->escapeHtmlAttr($tagFilter) ?>"
                                   placeholder="<?= $escaper->escapeHtmlAttr(__('e.g., cat_p_42')) ?>"/>
                        </div>
                        <div class="trident-filter-field">
                            <label for="trident_sort"><?= $escaper->escapeHtml(__('Sort By')) ?></label>
                            <select id="trident_sort" name="sort" class="admin__control-select">
                                <option value="age" <?= $sort === 'age' ? 'selected' : '' ?>><?= $escaper->escapeHtml(__('Age')) ?></option>
                                <option value="size" <?= $sort === 'size' ? 'selected' : '' ?>><?= $escaper->escapeHtml(__('Size')) ?></option>
                                <option value="hits" <?= $sort === 'hits' ? 'selected' : '' ?>><?= $escaper->escapeHtml(__('Hits')) ?></option>
                                <option value="ttl" <?= $sort === 'ttl' ? 'selected' : '' ?>><?= $escaper->escapeHtml(__('TTL')) ?></option>
                            </select>
                        </div>
                        <div class="trident-filter-actions">
                            <button type="submit" class="action-default scalable">
                                <span><?= $escaper->escapeHtml(__('Search')) ?></span>
                            </button>
                            <?php if ($tagFilter): ?>
                                <a href="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries')) ?>" class="action-default scalable">
                                    <span><?= $escaper->escapeHtml(__('Clear')) ?></span>
                                </a>
                            <?php endif; ?>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Results Info -->
            <div class="trident-results-info">
                <span>
                    <?= $escaper->escapeHtml(__(
                        'Showing %1-%2 of %3 entries',
                        $viewModel->formatNumber($total > 0 ? $offset + 1 : 0),
                        $viewModel->formatNumber(min($offset + $limit, $total)),
                        $viewModel->formatNumber($total)
                    )) ?>
                    <?php if ($tagFilter): ?>
                        &mdash; <?= $escaper->escapeHtml(__('filtered by tag:')) ?>
                        <span class="trident-tag-badge"><?= $escaper->escapeHtml($tagFilter) ?></span>
                    <?php endif; ?>
                </span>
            </div>

            <!-- Entries Table -->
            <?php if (!empty($entries)): ?>
                <div class="trident-table-wrapper">
                    <table class="admin__table-primary trident-entries-table">
                        <thead>
                            <tr>
                                <th><?= $escaper->escapeHtml(__('Path')) ?></th>
                                <th><?= $escaper->escapeHtml(__('Host')) ?></th>
                                <th><?= $escaper->escapeHtml(__('Method')) ?></th>
                                <th class="trident-col-right"><?= $escaper->escapeHtml(__('Size')) ?></th>
                                <th class="trident-col-right"><?= $escaper->escapeHtml(__('TTL')) ?></th>
                                <th class="trident-col-right"><?= $escaper->escapeHtml(__('Age')) ?></th>
                                <th class="trident-col-right"><?= $escaper->escapeHtml(__('Hits')) ?></th>
                                <th><?= $escaper->escapeHtml(__('Tags')) ?></th>
                                <th><?= $escaper->escapeHtml(__('Actions')) ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($entries as $entry): ?>
                                <?php
                                $urlKey = $entry['url_key'] ?? '';
                                $parsed = $viewModel->parseUrlKey($urlKey);
                                $entryTags = $entry['tags'] ?? [];
                                sort($entryTags);
                                $size = (int)($entry['size'] ?? 0);
                                $ttl = (int)($entry['ttl_remaining'] ?? 0);
                                $age = (int)($entry['age'] ?? 0);
                                $hits = (int)($entry['hits'] ?? 0);
                                ?>
                                <tr id="entry-<?= $escaper->escapeHtmlAttr(md5($urlKey)) ?>">
                                    <td class="trident-col-url" title="<?= $escaper->escapeHtmlAttr($parsed['path']) ?>">
                                        <code><?= $escaper->escapeHtml($parsed['path']) ?></code>
                                    </td>
                                    <td><?= $escaper->escapeHtml($parsed['host']) ?></td>
                                    <td><span class="trident-method-badge"><?= $escaper->escapeHtml($parsed['method']) ?></span></td>
                                    <td class="trident-col-right"><?= $escaper->escapeHtml($viewModel->formatBytes($size)) ?></td>
                                    <td class="trident-col-right"><?= $escaper->escapeHtml($viewModel->formatNumber($ttl)) ?>s</td>
                                    <td class="trident-col-right"><?= $escaper->escapeHtml($viewModel->formatNumber($age)) ?>s</td>
                                    <td class="trident-col-right"><?= $escaper->escapeHtml($viewModel->formatNumber($hits)) ?></td>
                                    <td class="trident-col-tags">
                                        <?php $tagId = 'tags-' . md5($urlKey); ?>
                                        <?php foreach (array_slice($entryTags, 0, 5) as $tag): ?>
                                            <a href="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries', ['tag_filter' => $tag])) ?>"
                                               class="trident-tag-badge"
                                               title="<?= $escaper->escapeHtmlAttr(__('Filter by tag: %1', $tag)) ?>">
                                                <?= $escaper->escapeHtml($tag) ?>
                                            </a>
                                        <?php endforeach; ?>
                                        <?php if (count($entryTags) > 5): ?>
                                            <button type="button"
                                                    class="trident-tag-badge trident-tag-more trident-tag-expand"
                                                    data-target="<?= $escaper->escapeHtmlAttr($tagId) ?>"
                                                    title="<?= $escaper->escapeHtmlAttr(__('Show all %1 tags', count($entryTags))) ?>">
                                                +<?= count($entryTags) - 5 ?>
                                            </button>
                                            <span id="<?= $escaper->escapeHtmlAttr($tagId) ?>" class="trident-tags-hidden" style="display:none;">
                                                <?php foreach (array_slice($entryTags, 5) as $tag): ?>
                                                    <a href="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries', ['tag_filter' => $tag])) ?>"
                                                       class="trident-tag-badge"
                                                       title="<?= $escaper->escapeHtmlAttr(__('Filter by tag: %1', $tag)) ?>">
                                                        <?= $escaper->escapeHtml($tag) ?>
                                                    </a>
                                                <?php endforeach; ?>
                                            </span>
                                        <?php endif; ?>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="action-default scalable trident-purge-btn"
                                                data-url="<?= $escaper->escapeHtmlAttr($parsed['scheme'] . '://' . $parsed['host'] . $parsed['path']) ?>"
                                                data-host="<?= $escaper->escapeHtmlAttr($parsed['host']) ?>"
                                                data-row="entry-<?= $escaper->escapeHtmlAttr(md5($urlKey)) ?>">
                                            <span><?= $escaper->escapeHtml(__('Purge')) ?></span>
                                        </button>
                                    </td>
                                </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <?php if ($totalPages > 1): ?>
                    <div class="trident-pagination">
                        <?php if ($page > 1): ?>
                            <a href="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries', [
                                'page' => $page - 1,
                                'tag_filter' => $tagFilter,
                                'sort' => $sort,
                            ])) ?>" class="action-default scalable">
                                <span><?= $escaper->escapeHtml(__('Previous')) ?></span>
                            </a>
                        <?php endif; ?>

                        <span class="trident-page-info">
                            <?= $escaper->escapeHtml(__('Page %1 of %2', $page, $totalPages)) ?>
                        </span>

                        <?php if ($page < $totalPages): ?>
                            <a href="<?= $escaper->escapeUrl($block->getUrl('trident/cache/entries', [
                                'page' => $page + 1,
                                'tag_filter' => $tagFilter,
                                'sort' => $sort,
                            ])) ?>" class="action-default scalable">
                                <span><?= $escaper->escapeHtml(__('Next')) ?></span>
                            </a>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>
            <?php else: ?>
                <div class="message message-notice">
                    <span><?= $escaper->escapeHtml(__('No cache entries found.')) ?></span>
                </div>
            <?php endif; ?>
        <?php endif; ?>
    <?php endif; ?>
</div>

<script>
    (function() {
        var purgeUrl = '<?= $escaper->escapeJs($block->getUrl('trident/cache/purgeEntry')) ?>';
        var formKey = '<?= $escaper->escapeJs($block->getFormKey()) ?>';

        document.querySelectorAll('.trident-tag-expand').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var target = document.getElementById(btn.getAttribute('data-target'));
                if (target) {
                    target.style.display = 'inline';
                    btn.style.display = 'none';
                }
            });
        });

        document.querySelectorAll('.trident-purge-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                if (!confirm('<?= $escaper->escapeJs(__('Are you sure you want to purge this entry?')) ?>')) {
                    return;
                }

                var url = btn.getAttribute('data-url');
                var host = btn.getAttribute('data-host');
                var rowId = btn.getAttribute('data-row');

                btn.disabled = true;
                btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Purging...')) ?>';

                fetch(purgeUrl + '?form_key=' + encodeURIComponent(formKey), {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        url: url,
                        host: host
                    })
                })
                .then(function(response) {
                    if (!response.ok) {
                        throw new Error('HTTP ' + response.status);
                    }
                    return response.json();
                })
                .then(function(data) {
                    if (data.success) {
                        var row = document.getElementById(rowId);
                        if (row) {
                            row.style.opacity = '0.4';
                            row.style.textDecoration = 'line-through';
                        }
                        btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Purged')) ?>';
                        btn.classList.add('trident-purged');
                    } else {
                        btn.disabled = false;
                        btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Purge')) ?>';
                        alert(data.message || '<?= $escaper->escapeJs(__('Failed to purge entry')) ?>');
                    }
                })
                .catch(function() {
                    btn.disabled = false;
                    btn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Purge')) ?>';
                    alert('<?= $escaper->escapeJs(__('Network error. Please try again.')) ?>');
                });
            });
        });
    })();
</script>
